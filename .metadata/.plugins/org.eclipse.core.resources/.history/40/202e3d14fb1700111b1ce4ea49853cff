package com.klu.Skill14_SpringSetterInjection;

public class Car {

    private Engine engine;

    // Default constructor (for Setter Injection)
    public Car() {
    }

    // Constructor Injection
    public Car(Engine engine) {
        this.engine = engine;
    }

    public void setEngine(Engine engine) {
        this.engine = engine;
    }

    public void drive(String type) {
        engine.start();
        System.out.println("Car is running using " + type);
    }
}